# Azure OpenAI (used locally and on Azure Container Apps)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# SharePoint access — two selectable backends (app/tools/sharepoint_tool.py)
SHAREPOINT_SITE_URL=https://<tenant>.sharepoint.com/sites/<site>
SHAREPOINT_TOOL_BACKEND=azure_function
# azure_function backend (default): sharepoint-csom-service/, PnP Core SDK + Managed Identity
SHAREPOINT_FUNCTION_URL=http://localhost:7071
# python backend ("explore" option): unimplemented .NET CSOM/PnP Framework sidecar
SHAREPOINT_SERVICE_URL=http://localhost:5080

# Fabric MCP context (Agent 4) — app/nodes/agent4_fabric_context.py
# Managed Identity auth; only override if not using the public Fabric MCP endpoint
# FABRIC_MCP_URL=https://api.fabric.microsoft.com/v1/mcp/core

# --- Foundry Hosted Agent (injected automatically by the platform at runtime) ---
# FOUNDRY_PROJECT_ENDPOINT=
# APPLICATIONINSIGHTS_CONNECTION_STRING=
